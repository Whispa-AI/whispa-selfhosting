# =============================================================================
# Whispa Self-Hosting - Pulumi Configuration Template
# =============================================================================
#
# QUICK START:
#   1. Copy this file:  cp Pulumi.dev.yaml.example Pulumi.<your-stack>.yaml
#   2. Fill in the REQUIRED values below (replace all "CHANGE_ME" placeholders)
#   3. Set secrets via CLI (cannot be stored in plain YAML):
#        pulumi config set --secret whispa:superuserPassword "your-password"
#   4. Deploy:  pulumi stack init <your-stack> && pulumi up
#
# See docs/CONFIGURATION.md for full details on all options.
# =============================================================================

config:
  # ===================
  # REQUIRED - You must fill these in
  # ===================

  # AWS Region for all resources
  aws:region: CHANGE_ME  # e.g., us-east-1, ap-southeast-2, eu-west-1

  # Your domain name for Whispa
  whispa:domainName: CHANGE_ME  # e.g., whispa.yourcompany.com

  # Frontend URL (must match domainName with https://)
  whispa:frontendUrl: CHANGE_ME  # e.g., https://whispa.yourcompany.com

  # Verified SES sender email
  # Verify first: AWS Console > SES > Verified identities > Create identity
  whispa:mailFrom: CHANGE_ME  # e.g., noreply@yourcompany.com

  # SSL Certificate - choose ONE of the following approaches:

  # OPTION A (recommended): Auto-provision via Route53
  # Requires a Route53 hosted zone for your domain
  whispa:autoCertificate: true
  whispa:hostedZoneId: CHANGE_ME  # e.g., Z0123456789ABCDEFGHIJ

  # OPTION B: Provide an existing ACM certificate ARN
  # whispa:certificateArn: arn:aws:acm:REGION:ACCOUNT:certificate/ID

  # ===================
  # STRONGLY RECOMMENDED - Bootstrap Admin User
  # ===================
  # Created automatically during first deployment. Without this, you'll
  # need to manually promote a user via ECS Exec after deployment.

  whispa:superuserEmail: CHANGE_ME  # e.g., admin@yourcompany.com
  # Set password via CLI:
  #   pulumi config set --secret whispa:superuserPassword "your-secure-password"

  # ===================
  # Speech-to-Text Provider
  # ===================

  # amazon (recommended) - uses IAM role, no API key needed
  # deepgram - requires: pulumi config set --secret whispa:deepgramApiKey "KEY"
  # elevenlabs - requires: pulumi config set --secret whispa:elevenlabsApiKey "KEY"
  # assemblyai - requires: pulumi config set --secret whispa:assemblyaiApiKey "KEY"
  whispa:transcriptionProvider: amazon

  # ===================
  # LLM Configuration
  # ===================

  # Default is AWS Bedrock — no API key, no model config needed. The deployment
  # grants Bedrock IAM permissions and the backend picks a region-appropriate
  # Claude Haiku 4.5 inference profile automatically. Leave everything below unset
  # for the common case.
  #
  # whispa:llmProvider: bedrock          # bedrock (default) | openrouter | openai
  # whispa:bedrockRegion: ap-southeast-2 # only if Bedrock must run in a different region than aws:region

  # OpenRouter instead of Bedrock (requires an API key + an explicit model):
  # whispa:llmProvider: openrouter
  # whispa:llmModelDefault: openrouter/google/gemini-2.5-flash
  # Set with: pulumi config set --secret whispa:llmApiKey YOUR_KEY

  # Advanced — pin a specific model or override per analyzer (provider prefix required;
  # use the inference-profile IDs from your AWS Bedrock console):
  # whispa:llmModelDefault: bedrock/au.anthropic.claude-haiku-4-5-20251001-v1:0
  # whispa:llmModelSummary: bedrock/au.anthropic.claude-sonnet-4-6-...

  # ===================
  # Optional - Resource Naming
  # ===================

  # Custom prefix for all AWS resources (e.g., "acme-prod")
  # If not set, resources are named: whispa-{stack-name}-{type}
  # whispa:resourcePrefix: acme-prod

  # ===================
  # Optional - API Domain (for host-based routing)
  # ===================

  # Separate domain for API traffic (e.g., api.whispa.yourcompany.com)
  # If set, Route53 will create a record for this too
  # whispa:apiDomainName: api.whispa.yourcompany.com

  # ===================
  # Optional - Email Settings
  # ===================

  # whispa:mailFromName: Whispa              # Sender display name (default: Whispa)
  # whispa:feedbackEmail: support@yourcompany.com  # Feedback email (default: same as mailFrom)

  # ===================
  # Optional - Database Sizing
  # ===================

  # Defaults are suitable for small-medium deployments
  # whispa:dbInstanceClass: db.t3.medium    # RDS instance type
  # whispa:dbAllocatedStorage: "20"         # Storage in GB
  # whispa:dbMultiAz: "true"               # Enable for production HA
  # whispa:dbBackupRetentionDays: "7"       # Backup retention

  # ===================
  # Optional - ECS Compute Sizing
  # ===================

  # Defaults are suitable for small-medium deployments
  # whispa:backendCpu: "512"         # 0.5 vCPU (256, 512, 1024, 2048, 4096)
  # whispa:backendMemory: "1024"     # 1 GB
  # whispa:frontendCpu: "256"        # 0.25 vCPU
  # whispa:frontendMemory: "512"     # 512 MB
  # whispa:desiredCount: "1"         # Task replicas (use 2+ for production HA)

  # ===================
  # Optional - App Version
  # ===================

  # The infra you checked out already defaults to its matching app version, so
  # you normally set nothing here. Set imageTag only to pin a different version:
  # whispa:imageTag: "0.0.71"
  #
  # Advanced: override the registry, or the full image refs (these win over imageTag):
  # whispa:imageRegistry: ghcr.io/whispa-ai
  # whispa:backendImage: ghcr.io/whispa-ai/whispa-backend:0.0.71
  # whispa:frontendImage: ghcr.io/whispa-ai/whispa-frontend:0.0.71

  # ===================
  # Optional - AWS Connect Integration
  # ===================

  # Set your Connect instance ID to enable real-time call transcription
  # API key for Lambda-to-backend auth is auto-generated
  # whispa:connectInstanceId: your-connect-instance-id
  # whispa:kvsStreamPrefix: whispa-connect

  # ===================
  # Optional - AI Voice Calls (LiveKit) + self-hosted streaming STT
  # ===================

  # Outbound AI-collector voice calls run an in-process LiveKit Agents worker.
  # It stays DORMANT unless liveKitUrl + both secrets below are all set.
  # whispa:liveKitUrl: wss://your-project.livekit.cloud
  # Secrets (set via CLI, never stored in YAML):
  #   pulumi config set --secret whispa:liveKitApiKey    YOUR_LIVEKIT_API_KEY
  #   pulumi config set --secret whispa:liveKitApiSecret YOUR_LIVEKIT_API_SECRET
  # Outbound dialing (Twilio Elastic SIP trunk bound to a LiveKit outbound trunk):
  # whispa:liveKitSipOutboundTrunkId: ST_xxxxxxxxxxxx
  # Worker name — defaults to "whispa-ai-collector-<stack>". Keep it unique per
  # environment: workers sharing a name against one LiveKit project form a single
  # pool and jobs round-robin across them (dev could steal prod's calls).
  # whispa:liveKitAiAgentName: whispa-ai-collector-dev

  # Streaming STT endpoint. Unset = AssemblyAI managed cloud. Point at a self-hosted
  # Universal-Streaming deployment for data residency (scheme+host[:port], no path).
  # The backend ECS task must have a network route + security-group egress to it.
  # whispa:assemblyaiStreamingBaseUrl: wss://aai-streaming.internal:8080
  # For self-hosted, assemblyaiApiKey is the license-proxy auth value (often "self-hosted"):
  #   pulumi config set --secret whispa:assemblyaiApiKey self-hosted

  # AssemblyAI dynamic keyterm biasing. Off by default (billed separately). When on,
  # a scenario's seeded stt_keyterms are pushed to AssemblyAI after the first turn.
  # whispa:sttDynamicKeyterms: "true"
  # Adds the built-in AU collections vocabulary on top (only when the above is on):
  # whispa:sttKeytermDomainDefaults: "true"

  # ===================
  # Optional - Generic env var passthrough (experimental / fast-moving config)
  # ===================
  # Inject extra backend env vars WITHOUT a code change or release — handy for
  # experimental flags and new provider keys whose names may still change.
  #
  # Non-secret values -> extraEnv (visible in the task definition + logs):
  # whispa:extraEnv:
  #   SOME_FEATURE_FLAG: "true"
  #   CARTESIA_VOICE_ID: "a0e99841-..."
  #
  # Secret values -> extraSecrets (stored in Secrets Manager, injected via `secrets`).
  # Set each key on the CLI so the value is encrypted — never paste a key here:
  #   pulumi config set --secret --path 'extraSecrets.CARTESIA_API_KEY' sk-cartesia-...
  #
  # Once a var is permanent, promote it to a typed WhispaConfig property (defaults +
  # validation + discoverability). extraEnv/extraSecrets are the fast lane, not the home.

  # ===================
  # Optional - Feature Flags
  # ===================

  # whispa:showSignupCta: "false"           # Show signup CTA (default: false for self-hosted)

  # ===================
  # Optional - Observability
  # ===================

  # whispa:sentryDsn: https://xxx@sentry.io/xxx

  # RDS I/O CloudWatch alarms
  # Alarms are created automatically for the RDS instance managed by this stack
  # when you provide either an existing SNS topic ARN or an email address.
  # If only alarmEmailAddress is set, Pulumi creates an SNS topic and subscribes the address.
  # whispa:enableRdsIoAlarms: "true"
  # whispa:alarmEmailAddress: dba-alerts@yourcompany.com
  # whispa:alarmSnsTopicArn: arn:aws:sns:us-east-1:123456789012:existing-topic
  # whispa:rdsInstanceIdentifiers:
  #   - shared-postgres-instance
  # whispa:rdsClusterIdentifiers:
  #   - shared-aurora-cluster
  # whispa:rdsDiskQueueDepthAlarmThreshold: "10"
  # whispa:rdsReadIopsAlarmThreshold: "1000"
  # whispa:rdsWriteIopsAlarmThreshold: "1000"
  # whispa:rdsFreeStorageSpaceAlarmThreshold: "5368709120"       # 5 GiB
  # whispa:rdsFreeableMemoryAlarmThreshold: "268435456"          # 256 MiB
  # whispa:rdsCpuUtilizationAlarmThreshold: "80"
  # whispa:rdsFreeLocalStorageAlarmThreshold: "2147483648"       # 2 GiB
  # whispa:rdsVolumeReadIopsAlarmThreshold: "1000"
  # whispa:rdsVolumeWriteIopsAlarmThreshold: "1000"
  # whispa:auroraMySqlClusterIdentifiers:
  #   - aurora-mysql-cluster
  # whispa:auroraVolumeBytesLeftTotalAlarmThreshold: "10737418240"  # 10 GiB

  # Langfuse LLM observability (optional)
  # whispa:langfusePublicKey: pk-lf-...
  # whispa:langfuseHost: https://cloud.langfuse.com
  # Set with: pulumi config set --secret whispa:langfuseSecretKey YOUR_KEY
