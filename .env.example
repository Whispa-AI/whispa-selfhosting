# Whispa Self-Hosting Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# Database
DATABASE_URL=postgresql://whispa:password@localhost:5432/whispa

# JWT Secrets (generate with: openssl rand -hex 32)
ACCESS_SECRET_KEY=your-access-secret-key-here
REFRESH_SECRET_KEY=your-refresh-secret-key-here
RESET_PASSWORD_SECRET_KEY=your-reset-password-secret-key-here
VERIFICATION_SECRET_K EY=your-verification-secret-key-here

# LLM Provider (OpenRouter recommended)
LLM_API_KEY=sk-or-your-openrouter-api-key
LLM_BASE_URL=https://openrouter.ai/api/v1

# Speech-to-Text (choose one)
DEEPGRAM_API_KEY=your-deepgram-api-key
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# AI Voice Calls (LiveKit) — optional; the in-process AI-call worker stays
# dormant unless LIVEKIT_URL + key + secret are all set.
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-livekit-api-key
# LIVEKIT_API_SECRET=your-livekit-api-secret
# LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxx
# LIVEKIT_AI_AGENT_NAME=whispa-ai-collector-dev   # keep unique per environment

# Self-hosted AssemblyAI streaming STT (omit to use AssemblyAI's managed cloud).
# scheme+host[:port], no path — both streaming paths append "/v3/ws".
# ASSEMBLYAI_STREAMING_BASE_URL=wss://aai-streaming.internal:8080
# ASSEMBLYAI_API_KEY=self-hosted   # license-proxy auth value when self-hosting

# Frontend URL (for CORS)
FRONTEND_URL=https://whispa.yourcompany.com
CORS_ORIGINS=["https://whispa.yourcompany.com"]

# =============================================================================
# Optional Configuration
# =============================================================================

# Email (AWS SES)
# MAIL_FROM=noreply@yourcompany.com
# MAIL_FROM_NAME=Whispa
# AWS_SES_REGION=us-east-1

# S3 Audio Storage
# S3_AUDIO_BUCKET=whispa-audio-yourcompany
# S3_AUDIO_REGION=us-east-1

# Error Tracking (Sentry)
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# LLM Observability (Langfuse)
# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# PII Scrubbing
PII_SCRUB_ENABLED=true
PII_SCRUB_BEFORE_DATABASE=true
PII_SCRUB_BEFORE_LLM=false
PII_REPLACEMENT_TEXT=[REDACTED]

# Feature Flags
SHOW_SIGNUP_CTA=true
